# PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_SSL=true

# API Authentication
CRM_API_KEY=your-shared-api-key-here
JWT_SECRET=your-jwt-secret-here-min-32-chars

# IBM App ID (for enterprise SSO token verification)
IBM_APPID_DISCOVERY_ENDPOINT=https://us-south.appid.cloud.ibm.com/oauth/v4/TENANT_ID/.well-known/openid-configuration
IBM_APPID_CLIENT_ID=your-appid-client-id

# IBM Cloud Object Storage
IBM_COS_API_KEY=your-cos-iam-api-key
IBM_COS_INSTANCE_ID=crn:v1:bluemix:public:cloud-object-storage:global:a/ACCOUNT:INSTANCE::
IBM_COS_ENDPOINT=s3.us-south.cloud-object-storage.appdomain.cloud

# Server
PORT=8080
